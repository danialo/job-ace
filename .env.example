# Job Ace Configuration
# Copy this to .env and fill in your values

# Database
JOB_ACE_DATABASE_URL=sqlite:///./db.sqlite3

# LLM Provider: "stub" (default) or "anthropic"
JOB_ACE_LLM_PROVIDER=stub

# Anthropic API Configuration (required if LLM_PROVIDER=anthropic)
JOB_ACE_ANTHROPIC_API_KEY=sk-ant-xxxxx
JOB_ACE_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# LLM Tuning (optional)
JOB_ACE_LLM_MAX_TOKENS=4096
JOB_ACE_LLM_TEMPERATURE=0.3

# Browser Automation
JOB_ACE_PLAYWRIGHT_HEADLESS=true

# Artifacts
JOB_ACE_DATA_ROOT=artifacts
